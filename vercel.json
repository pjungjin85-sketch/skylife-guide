{
  "routes": [
    { "src": "/", "dest": "/mobile_sales_guide.html" },
    { "src": "/inquiry", "dest": "/inquiry.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
